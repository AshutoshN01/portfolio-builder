# Portfolio Builder — Environment Variables Template
# Copy this file to '.env' or '.env.local' and fill in your values.
# Keys prefixed with VITE_ are exposed to the browser bundle.

# ── Site Canonical URL ──────────────────────────────────────────────
VITE_SITE_URL=https://john-doe.dev

# ── Profile Personalization ──────────────────────────────────────────
VITE_PROFILE_NAME="John Doe"
VITE_PROFILE_TITLE="Software Developer"
VITE_PROFILE_TAGLINE="Developer | Builder | Creator"
VITE_PROFILE_EMAIL="john.doe@example.com"
VITE_PROFILE_LOCATION="San Francisco, CA"
VITE_PROFILE_RESUME_URL=""
VITE_PROFILE_BIO="A passionate software developer focused on building clean, performant, and user-friendly web applications."

# ── Social Media & Networks ──────────────────────────────────────────
VITE_SOCIAL_GITHUB=https://github.com/john-doe
VITE_SOCIAL_LINKEDIN=https://linkedin.com/in/john-doe
VITE_SOCIAL_TWITTER=https://x.com/john_doe
VITE_SOCIAL_TWITTER_HANDLE=@john_doe

# ── Contact API Endpoints ─────────────────────────────────────────────
# 1. Formspree Endpoint (Recommended)
VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your_form_id

# 2. EmailJS Credentials (Alternative backend)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── Analytics Integration Configuration ──────────────────────────────
# Google Analytics 4 ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics custom domain
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Vercel Web Insights toggle (true/false)
VITE_ENABLE_VERCEL_ANALYTICS=false

# ── Social Visual assets ─────────────────────────────────────────────
VITE_SEO_OG_IMAGE=/assets/og-image.webp
VITE_SEO_DESCRIPTION="Portfolio of John Doe, Software Developer."

# ── Firebase Services Configuration (Portfolio Builder) ──────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
